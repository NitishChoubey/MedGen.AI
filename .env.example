# MedGen.AI full-stack environment reference
# Use service-specific files where possible:
# - apps/web/.env.example
# - services/api/.env.example

# =========================
# Web App (apps/web)
# =========================
DATABASE_URL=postgresql://user:password@host:5432/medgen
NEXTAUTH_URL=https://your-web-service.onrender.com
NEXTAUTH_SECRET=replace-with-a-long-random-string
AUTH_TRUST_HOST=true
NEXT_PUBLIC_API_URL=https://your-api-service.onrender.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# =========================
# API Service (services/api)
# =========================
PORT=8000
FRONTEND_URL=https://your-web-service.onrender.com
KB_DIR=../../kb
HF_TOKEN=
SUMMARIZATION_MODEL=sshleifer/distilbart-cnn-12-6
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
