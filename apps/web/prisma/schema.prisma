// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Note: Role and status are currently modeled as String for compatibility.
// Valid roles: DOCTOR, PATIENT
// Valid statuses: ACTIVE, SUSPENDED, PENDING_VERIFICATION, INACTIVE

// User Model
model User {
  id                String         @id @default(cuid())
  email             String         @unique
  emailVerified     DateTime?
  password          String?        // Nullable for OAuth users
  name              String?
  image             String?
  role              String         @default("DOCTOR")
  status            String         @default("PENDING_VERIFICATION")
  
  // Professional Information (for DOCTOR role)
  hospital          String?
  department        String?
  specialty         String?
  licenseNumber     String?        @unique
  phone             String?
  
  // Patient Information (for PATIENT role)
  dateOfBirth       DateTime?
  gender            String?        // MALE, FEMALE, OTHER
  bloodType         String?        // A+, A-, B+, B-, AB+, AB-, O+, O-
  allergies         String?        // JSON array of allergies
  medicalHistory    String?        // JSON array of medical conditions
  emergencyContact  String?        // JSON object with name and phone
  
  // Settings & Preferences
  darkMode          Boolean        @default(false)
  language          String         @default("en")
  notifications     Boolean        @default(true)
  
  // Subscription & Limits
  subscriptionTier  String         @default("FREE") // FREE, PRO, HOSPITAL, ENTERPRISE
  monthlyAnalyses   Int            @default(0)      // Counter reset monthly
  analysisLimit     Int            @default(10)     // Based on subscription
  
  // Relationships
  accounts          Account[]
  sessions          Session[]
  analyses          Analysis[]
  apiKeys           ApiKey[]
  auditLogs         AuditLog[]
  
  // Appointment relationships
  patientAppointments   Appointment[]      @relation("PatientAppointments")
  doctorAppointments    Appointment[]      @relation("DoctorAppointments")
  doctorAvailability    DoctorAvailability[]
  
  // Timestamps
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  lastLoginAt       DateTime?
  
  @@index([email])
  @@index([role])
  @@index([status])
}

// OAuth Accounts (Google, GitHub, etc.)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// Session Management
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Email Verification Tokens
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Password Reset Tokens
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([token])
}

// Medical Analysis Records
model Analysis {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Input Data
  patientNote   String
  patientId     String?  // Anonymized patient identifier
  patientName   String?  // Patient name for display
  documentType  String   @default("medical_report") // medical_report, lab_results, prescription, etc.
  originalFileName String? // Original uploaded file name
  
  // AI Results (Raw - before doctor review)
  summary       String
  diagnoses     String   // Array of top 5 diagnoses with confidence scores
  findings      String   // Key findings extracted
  citations     String   // KB citations used
  
  // Doctor Review Fields
  reviewStatus    String  @default("ai_processing") // ai_processing, pending_review, approved, rejected
  reviewedBy      String? // Doctor user ID who reviewed
  reviewedAt      DateTime?
  reviewNotes     String? // Doctor's notes on the review
  
  // Edited content (doctor can modify AI output)
  editedSummary   String? // Doctor's edited version of summary
  editedDiagnoses String? // Doctor's edited diagnoses
  editedFindings  String? // Doctor's edited findings
  
  // Final approved content (what patient sees)
  finalSummary    String? // Approved summary for patient
  finalDiagnoses  String? // Approved diagnoses for patient
  finalFindings   String? // Approved findings for patient
  
  // Metadata
  processingTime Float   @default(0) // In seconds
  modelVersion   String  @default("v1.0")
  status         String  @default("COMPLETED") // PENDING, PROCESSING, COMPLETED, FAILED
  priority       String  @default("normal") // low, normal, high, urgent
  
  // Collaboration
  sharedWith    String   // Array of user IDs stored as JSON
  isPublic      Boolean  @default(false)
  tags          String   // Array of tags stored as JSON
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([userId])
  @@index([createdAt])
  @@index([status])
  @@index([reviewStatus])
  @@index([reviewedBy])
}

// API Keys for Programmatic Access
model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  name        String   // e.g., "Production API", "Test Key"
  key         String   @unique
  
  // Usage & Limits
  usageCount  Int      @default(0)
  rateLimit   Int      @default(100) // Requests per day
  lastUsedAt  DateTime?
  
  // Status
  active      Boolean  @default(true)
  expiresAt   DateTime?
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([userId])
  @@index([key])
}

// Audit Logs for HIPAA Compliance
model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Action Details
  action      String   // LOGIN, LOGOUT, CREATE_ANALYSIS, VIEW_ANALYSIS, EXPORT, etc.
  resourceId  String?  // ID of the resource being accessed (e.g., analysisId)
  resourceType String? // ANALYSIS, USER, SETTINGS, etc.
  
  // Request Details
  ipAddress   String?
  userAgent   String?
  metadata    String?  // Additional context
  
  // Result
  success     Boolean  @default(true)
  errorMessage String?
  
  // Timestamp
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

// Knowledge Base Articles (For Admin Management)
model KnowledgeBase {
  id            String   @id @default(cuid())
  
  // Content
  condition     String   @unique // e.g., "Heart Failure", "Pneumonia"
  description   String
  symptoms      String   // Array of symptoms
  diagnostics   String   // Diagnostic criteria
  treatment     String   // Treatment options
  references    String   // Medical references
  
  // Metadata
  version       String   @default("1.0")
  category      String   // CARDIOLOGY, PULMONOLOGY, etc.
  severity      String   // LOW, MEDIUM, HIGH, CRITICAL
  icd10Codes    String   // ICD-10 codes stored as JSON array
  
  // Management
  active        Boolean  @default(true)
  reviewedBy    String?  // User ID of reviewer
  lastReviewedAt DateTime?
  
  // Timestamps
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@index([condition])
  @@index([category])
  @@index([active])
}

// Appointment Model
model Appointment {
  id            String   @id @default(cuid())
  
  // Patient (who booked)
  patientId     String
  patient       User     @relation("PatientAppointments", fields: [patientId], references: [id], onDelete: Cascade)
  
  // Doctor (who will attend)
  doctorId      String
  doctor        User     @relation("DoctorAppointments", fields: [doctorId], references: [id], onDelete: Cascade)
  
  // Appointment Details
  title         String           // e.g., "General Checkup", "Follow-up Visit"
  description   String?          // Additional notes from patient
  appointmentType String         @default("general") // general, specialist, follow_up, emergency, lab_test
  
  // Date & Time
  scheduledDate DateTime         // Date and time of appointment
  duration      Int              @default(30) // Duration in minutes
  
  // Status Management
  // PENDING: Patient booked, awaiting doctor approval
  // APPROVED: Doctor approved, confirmed
  // REJECTED: Doctor rejected the appointment
  // COMPLETED: Appointment has been completed
  // CANCELLED: Cancelled by patient or doctor
  // NO_SHOW: Patient didn't show up
  status        String           @default("PENDING")
  
  // Review/Response
  doctorNotes   String?          // Notes from doctor after approval/rejection
  rejectionReason String?        // Reason if rejected
  
  // Metadata
  isVirtual     Boolean          @default(false) // Telemedicine appointment
  meetingLink   String?          // Link for virtual appointments
  
  // Timestamps
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  approvedAt    DateTime?
  completedAt   DateTime?
  cancelledAt   DateTime?
  
  @@index([patientId])
  @@index([doctorId])
  @@index([scheduledDate])
  @@index([status])
}

// Doctor Availability Model
model DoctorAvailability {
  id          String   @id @default(cuid())
  
  // Doctor
  doctorId    String
  doctor      User     @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  
  // Day of week (0 = Sunday, 1 = Monday, ..., 6 = Saturday)
  dayOfWeek   Int
  
  // Time slots (stored as HH:MM format)
  startTime   String   // e.g., "09:00"
  endTime     String   // e.g., "17:00"
  
  // Slot duration in minutes
  slotDuration Int     @default(30)
  
  // Is this slot active?
  isActive    Boolean  @default(true)
  
  // Timestamps
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([doctorId, dayOfWeek, startTime])
  @@index([doctorId])
  @@index([dayOfWeek])
}
